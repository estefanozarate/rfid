{
  "expo": {
    "name": "stamping-rfid",
    "slug": "stamping-rfid",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "io.stamping.rfid",
      "infoPlist": {
        "NFCReaderUsageDescription": "stamping.io necesita acceso al NFC para leer tags RFID en eventos."
      },
      "entitlements": {
        "com.apple.developer.nfc.readersession.formats": [
          "NDEF",
          "TAG"
        ]
      }
    },
    "android": {
      "package": "io.stamping.rfid",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "permissions": [
        "android.permission.NFC"
      ]
    },
    "plugins": [
      [
        "react-native-nfc-manager",
        {
          "nfcPermission": "stamping.io requiere NFC para leer tags RFID en eventos.",
          "selectIdentifiers": [],
          "systemCodes": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "eas": {
        "projectId": "c8c02608-d2a9-4e5a-ab17-0199eb5e7c30"
      }
    }
  }
}
